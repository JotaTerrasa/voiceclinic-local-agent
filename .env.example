# Core
VOICECLINIC_DB=data/clinic.db

# Orchestration: direct or langgraph
ORCHESTRATION_MODE=direct

# LLM provider: ollama, openai, or none
LLM_PROVIDER=ollama

# Local LLM through Ollama. Recommended for a single RTX 4090 24GB:
# ollama pull qwen3:30b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:30b
OLLAMA_TIMEOUT_SECONDS=20

# OpenAI provider. Keep OPENAI_API_KEY empty unless LLM_PROVIDER=openai.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20

# Local STT
WHISPER_MODEL=small

# Local TTS. Download a Spanish Piper voice and set the model path.
# If binaries are not in PATH, use absolute paths. On Windows, .exe paths are fine.
PIPER_BIN=piper
PIPER_MODEL=
PIPER_CONFIG=
FFMPEG_BIN=ffmpeg

# Asterisk AudioSocket bridge
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9092
