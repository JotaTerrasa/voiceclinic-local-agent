# Core
VOICECLINIC_DB=data/clinic.db

# Local LLM. Recommended for a single RTX 4090 24GB:
# ollama pull qwen3:30b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:30b
OLLAMA_TIMEOUT_SECONDS=20

# Local STT
WHISPER_MODEL=small

# Local TTS. Download a Spanish Piper voice and set the model path.
PIPER_BIN=piper
PIPER_MODEL=
PIPER_CONFIG=
FFMPEG_BIN=ffmpeg

# Asterisk AudioSocket bridge
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9092
